PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/tradexgg
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Preco das skins: site_price = market_price * PRICE_ADJUST_FACTOR
# 1.0 = mesmo preco do mercado Steam (padrao)
# 0.95 = 5% abaixo do mercado
PRICE_ADJUST_FACTOR=1.0

# Intervalo de atualizacao de precos (horas)
PRICE_CACHE_HOURS=6

# =====================================================
# Pricempire API (recomendado - substitui Steam API direta)
# Consolida precos de 50+ sites: Steam, Buff, Skinport, etc.
# Plano gratuito disponivel em: https://pricempire.com
# Como obter: pricempire.com > conta > Settings > API
# =====================================================
PRICEMPIRE_API_KEY=sua-api-key-aqui
PRICEMPIRE_SOURCE=steam
PRICEMPIRE_CACHE_HOURS=12

# =====================================================
# Email (Gmail SMTP) — recuperacao de senha
# Use uma "Senha de App" (nao a senha normal do Google)
# Como obter: myaccount.google.com > Seguranca > Verificacao em 2 etapas > Senhas de app
# =====================================================
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SITE_URL=https://seu-site.com
